# ──────────────────────────────────────────────────────────────
# Configuración del backend — Sistema de Facturación (Sirumatek)
# Copia este archivo a .env y ajusta los valores.
# ──────────────────────────────────────────────────────────────

# Entorno: development | production | test
NODE_ENV=development

# Puerto de la API
PORT=3000

# Prefijo global de rutas (ej. /api/v1)
API_PREFIX=api

# ── Base de datos (PostgreSQL) ─────────────────────────────────
# Debe coincidir con docker-compose.yml en desarrollo.
DATABASE_URL=postgresql://facturador:facturador@localhost:5432/facturador?schema=public

# ── Redis (colas / cache) ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Object Storage (S3 / MinIO en desarrollo) ─────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=facturador

# ── Autenticación (JWT) ────────────────────────────────────────
# Genera secretos largos y aleatorios para producción.
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-largo-y-aleatorio
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (ej. el frontend).
CORS_ORIGINS=http://localhost:3001

# ── Rate limiting ──────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ── Validador de contribuyentes del SENIAT (RN-101) ───────────
SENIAT_VALIDADOR_URL=https://appmovil.seniat.gob.ve/api/validador-contribuyente
SENIAT_TIMEOUT_MS=8000
# true = modo mock (dev, no llama a la API real); false = llama al SENIAT
SENIAT_MOCK=true

# ── Imprenta Digital homologada (RN-007) ──────────────────────
IMPRENTA_BASE_URL=
IMPRENTA_TIMEOUT_MS=10000
# true = modo mock (dev, simula número de control); false = llama a la imprenta real
IMPRENTA_MOCK=true

# ── Microservicio de tasas BCV (USD/EUR) ──────────────────────
TASAS_BCV_URL=http://localhost:3005
TASAS_BCV_TIMEOUT_MS=6000
# true = modo mock (dev); false = consume el microservicio real
TASAS_BCV_MOCK=true
