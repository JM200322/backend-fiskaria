# Cadena de conexión PostgreSQL (recomendado)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST:5432/BNPL

# Ruta al CSV (opcional; por defecto usa Listado de Tasas Diarias.csv en la raíz del proyecto)
# CSV_PATH=/ruta/absoluta/al/archivo.csv

# Sincronización BCV (Docker scheduler / Nest CLI)
# BCV_PAGE_URL=https://www.bcv.org.ve/
# Si falla la verificación SSL contra el BCV: BCV_INSECURE_TLS=1
# BCV_SYNC_HOURS=8,14,20
# BCV_SYNC_RUN_ON_START=0

# API HTTP NestJS (Docker: servicio api / local: npm run api:start)
# API_PORT=3000
# API_HOST=0.0.0.0
