{
  "name": "tasas-bcv",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "api:start": "nest start",
    "start:prod": "node dist/main.js",
    "db:setup": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "db:setup:prod": "typeorm migration:run -d dist/database/data-source.js",
    "db:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "db:import": "npm run db:setup && ts-node -r tsconfig-paths/register src/cli.ts import:csv",
    "db:import:prod": "npm run db:setup:prod && node dist/cli.js import:csv",
    "bcv:sync": "ts-node -r tsconfig-paths/register src/cli.ts bcv:sync",
    "bcv:sync:prod": "node dist/cli.js bcv:sync",
    "bcv:scheduler:prod": "node dist/scheduler.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/typeorm": "^11.0.1",
    "cheerio": "^1.2.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.6.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/node": "^25.8.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
