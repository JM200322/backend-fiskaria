// Esquema de base de datos — Fiskaria (Sistema de Facturación Homologado)
// Fuente de verdad: repo SDD (Spec-Driven-Development-Fiscaria).
// Ver: arquitectura/base-de-datos.md, ADR-0002 (RBAC granular), módulo 11.
//
// Convenciones:
//   - Dinero como Decimal (NUNCA Float); tasas Decimal(18,6).
//   - Multi-tenant: una sola BD, separación lógica por contribuyenteId (RN-122).
//   - Tablas de identidad con PK uuid (ADR-0002).
//   - Documentos fiscales y auditoría: append-only desde la lógica de negocio.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Identidad y tenencia (multi-tenant) — RN-122, RN-124
// ──────────────────────────────────────────────────────────────

enum TipoContribuyente {
  ORDINARIO
  ESPECIAL
  FORMAL
}

enum PeriodoIva {
  QUINCENAL
  MENSUAL
}

/// Comercio afiliado (el "tenant"). Su alta la realiza Sirumatek (RN-134).
model Contribuyente {
  id                    String                 @id @default(uuid())
  rif                   String                 @unique
  razonSocial           String                 @map("razon_social")
  tipoContribuyente     TipoContribuyente      @default(ORDINARIO) @map("tipo_contribuyente")
  agenteRetencion       Boolean                @default(false) @map("agente_retencion") // habilita retenciones (RN-129)
  periodoIva            PeriodoIva?            @map("periodo_iva") // quincenal/mensual (RN-130)
  domicilioFiscal       String?                @map("domicilio_fiscal")
  validado              Boolean                @default(false) @map("validado") // vía API SENIAT (RN-101)
  usuarios              Usuario[]
  terceros              Tercero[]
  productos             Producto[]
  movimientosInventario MovimientoInventario[]
  categoriasComerciales CategoriaComercial[]
  puntosEmision         PuntoEmision[]
  documentos            DocumentoFiscal[]
  compras               Compra[]
  retenciones           ComprobanteRetencion[]
  planCuentas           PlanCuenta[]
  configsContables      ConfigCuentaContable[]
  asientos              Asiento[]
  declaraciones         Declaracion[]
  ventas                Venta[]
  actividadesEconomicas ActividadEconomica[]
  impuestosMunicipales  ImpuestoMunicipal[]
  retencionesRecibidas  RetencionRecibida[]
  auditoria             RegistroAuditoria[]
  talonarios            TalonarioAutorizado[]
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  @@map("contribuyentes")
}

// ──────────────────────────────────────────────────────────────
// Terceros (clientes / proveedores) — Módulo 06, RN-104, RN-008
// ──────────────────────────────────────────────────────────────

/// Un tercero puede ser cliente y/o proveedor a la vez (RN-104, no se duplica).
model Tercero {
  id                String                 @id @default(uuid())
  contribuyenteId   String                 @map("contribuyente_id")
  contribuyente     Contribuyente          @relation(fields: [contribuyenteId], references: [id])
  rif               String
  tipoId            String                 @map("tipo_id") // J, V, E, G, P, C (letra del RIF)
  nombre            String
  direccion         String?
  telefono          String?
  email             String?
  esCliente         Boolean                @default(true) @map("es_cliente")
  esProveedor       Boolean                @default(false) @map("es_proveedor")
  rifValidado       Boolean                @default(false) @map("rif_validado") // requerido para facturar (RN-008)
  activo            Boolean                @default(true)
  productos         ProductoProveedor[]
  documentosCliente DocumentoFiscal[]      @relation("ClienteDocumentos")
  comprasProveedor  Compra[]               @relation("ProveedorCompras")
  retencionesBenef  ComprobanteRetencion[] @relation("BeneficiarioRetenciones")
  ventas            Venta[]                @relation("VentasTercero")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  deletedAt         DateTime?              @map("deleted_at")

  @@unique([contribuyenteId, rif]) // un RIF no se duplica dentro del comercio
  @@index([contribuyenteId])
  @@map("terceros")
}

// ──────────────────────────────────────────────────────────────
// Inventario — Módulo 05 (RN-102 IVA híbrido, RN-121 stock)
// ──────────────────────────────────────────────────────────────

enum TipoProducto {
  ALMACENABLE
  CONSUMIBLE
  SERVICIO
}

enum UnidadMedida {
  UNID
  KG
  LT
  CAJA
  SACO
  PAQ
}

/// Catálogo GLOBAL: determina la alícuota de IVA (RN-102). No lleva contribuyente.
model CategoriaFiscal {
  id          String     @id @default(uuid())
  nombre      String     @unique
  alicuotaIva Decimal    @map("alicuota_iva") @db.Decimal(5, 2)
  productos   Producto[]

  @@map("categorias_fiscales")
}

/// Agrupación organizativa por comercio. NO determina el IVA (I-L1).
model CategoriaComercial {
  id              String        @id @default(uuid())
  contribuyenteId String        @map("contribuyente_id")
  contribuyente   Contribuyente @relation(fields: [contribuyenteId], references: [id])
  nombre          String
  productos       Producto[]
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([contribuyenteId, nombre])
  @@index([contribuyenteId])
  @@map("categorias_comerciales")
}

model Producto {
  id                   String                 @id @default(uuid())
  contribuyenteId      String                 @map("contribuyente_id")
  contribuyente        Contribuyente          @relation(fields: [contribuyenteId], references: [id])
  codigo               String
  nombre               String
  tipo                 TipoProducto           @default(ALMACENABLE)
  categoriaComercialId String?                @map("categoria_comercial_id")
  categoriaComercial   CategoriaComercial?    @relation(fields: [categoriaComercialId], references: [id])
  categoriaFiscalId    String                 @map("categoria_fiscal_id")
  categoriaFiscal      CategoriaFiscal        @relation(fields: [categoriaFiscalId], references: [id])
  ivaOverride          Decimal?               @map("iva_override") @db.Decimal(5, 2) // sobrescribe la alícuota de la categoría (RN-102)
  precio               Decimal                @db.Decimal(18, 2)
  stock                Decimal                @default(0) @db.Decimal(18, 3) // relevante solo si ALMACENABLE (RN-121)
  stockMinimo          Decimal                @default(0) @map("stock_minimo") @db.Decimal(18, 3) // umbral de alerta
  costoUltimo          Decimal?               @map("costo_ultimo") @db.Decimal(18, 2) // costo de la última reposición (base para margen y COGS)
  codigoBarras         String?                @map("codigo_barras")
  lote                 String?
  unidadMedida         UnidadMedida?          @map("unidad_medida")
  imagenUrl            String?                @map("imagen_url") // ruta pública servida por /uploads — set solo vía POST /productos/:id/imagen
  activo               Boolean                @default(true)
  proveedores          ProductoProveedor[]
  documentoItems       DocumentoItem[]
  ventaItems           VentaItem[]
  movimientos          MovimientoInventario[]
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  deletedAt            DateTime?              @map("deleted_at")

  @@unique([contribuyenteId, codigo])
  @@index([contribuyenteId])
  @@map("productos")
}

/// Historial de reposiciones de stock (entradas de inventario) — alimenta costoUltimo y el asiento automático.
model MovimientoInventario {
  id              String        @id @default(uuid())
  contribuyenteId String        @map("contribuyente_id")
  contribuyente   Contribuyente @relation(fields: [contribuyenteId], references: [id])
  productoId      String        @map("producto_id")
  producto        Producto      @relation(fields: [productoId], references: [id])
  cantidad        Decimal       @db.Decimal(18, 3)
  costoUnitario   Decimal       @map("costo_unitario") @db.Decimal(18, 2)
  costoTotal      Decimal       @map("costo_total") @db.Decimal(18, 2)
  ivaCredito      Decimal       @default(0) @map("iva_credito") @db.Decimal(18, 2)
  referencia      String?
  fecha           DateTime      @default(now())
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([contribuyenteId, productoId])
  @@map("movimientos_inventario")
}

/// Relación N:M producto ↔ proveedor (Tercero) — RN-104.
model ProductoProveedor {
  productoId String   @map("producto_id")
  terceroId  String   @map("tercero_id")
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  tercero    Tercero  @relation(fields: [terceroId], references: [id], onDelete: Cascade)

  @@id([productoId, terceroId])
  @@map("productos_proveedores")
}

// ──────────────────────────────────────────────────────────────
// Puntos de emisión y numeración correlativa — RN-006, RN-123, RN-128
// ──────────────────────────────────────────────────────────────

enum TipoDocumento {
  FACTURA
  NOTA_CREDITO
  NOTA_DEBITO
  GUIA_DESPACHO
  RETENCION_IVA
  RETENCION_ISLR
}

/// Sucursal/caja con numeración independiente (RN-123).
model PuntoEmision {
  id              String               @id @default(uuid())
  contribuyenteId String               @map("contribuyente_id")
  contribuyente   Contribuyente        @relation(fields: [contribuyenteId], references: [id])
  codigo          String
  nombre          String
  activo          Boolean              @default(true)
  secuencias      SecuenciaDocumento[]
  documentos      DocumentoFiscal[]
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@unique([contribuyenteId, codigo])
  @@index([contribuyenteId])
  @@map("puntos_emision")
}

/// Rango de números de control autorizado por el SENIAT para talonarios de
/// contingencia (Providencia 00071: formato NN-NNNNNNNN). No confundir con
/// `SecuenciaDocumento` (correlativo interno de Fiskaria): este rango es el
/// autorizado externamente que se consume solo si la imprenta digital falla.
model TalonarioAutorizado {
  id                String        @id @default(uuid())
  contribuyenteId   String        @map("contribuyente_id")
  contribuyente     Contribuyente @relation(fields: [contribuyenteId], references: [id])
  serie             String        @db.VarChar(2) // 2 dígitos identificadores de la máquina fiscal
  desde             Int // límite inferior del rango (parte secuencial, hasta 8 dígitos)
  hasta             Int // límite superior del rango
  consecutivoActual Int // próximo número a emitir; arranca en `desde`
  providenciaNum    String        @map("providencia_num") // N° de autorización SENIAT
  activo            Boolean       @default(true)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([contribuyenteId, serie])
  @@map("talonarios_autorizados")
}

/// Contador correlativo por (punto de emisión, tipo de documento) — RN-128.
/// `ultimo` se incrementa de forma atómica dentro de la transacción de emisión (RN-006).
model SecuenciaDocumento {
  id             String        @id @default(uuid())
  puntoEmisionId String        @map("punto_emision_id")
  puntoEmision   PuntoEmision  @relation(fields: [puntoEmisionId], references: [id], onDelete: Cascade)
  tipo           TipoDocumento
  ultimo         Int           @default(0)

  @@unique([puntoEmisionId, tipo])
  @@map("secuencias_documento")
}

// ──────────────────────────────────────────────────────────────
// Facturador — documentos fiscales (Módulo 02) — RN-001/006/007/008/009/010/120/128
// ──────────────────────────────────────────────────────────────

enum EstatusDocumento {
  NO_ENVIADO // creado, sin número de control de la imprenta (RN-112)
  ENVIADO // emitido, con número de control
  ANULADO_POR_REVERSO // corregido vía NC/ND (RN-002)
  CONTINGENCIA
}

enum MetodoPago {
  EFECTIVO_BS
  DIVISAS
  PAGO_MOVIL
  TARJETA
}

/// Documento fiscal (Factura, NC, ND, Guía…). Append-only: no se edita ni borra (RN-001).
model DocumentoFiscal {
  id                String            @id @default(uuid())
  contribuyenteId   String            @map("contribuyente_id")
  contribuyente     Contribuyente     @relation(fields: [contribuyenteId], references: [id])
  puntoEmisionId    String            @map("punto_emision_id")
  puntoEmision      PuntoEmision      @relation(fields: [puntoEmisionId], references: [id])
  tipo              TipoDocumento
  docNum            String            @map("doc_num") // correlativo interno (Fiskaria)
  numeroControl     String?           @map("numero_control") // lo asigna la imprenta (RN-007)
  estatus           EstatusDocumento  @default(NO_ENVIADO)
  clienteTerceroId  String            @map("cliente_tercero_id")
  cliente           Tercero           @relation("ClienteDocumentos", fields: [clienteTerceroId], references: [id])
  documentoOrigenId String?           @map("documento_origen_id")
  documentoOrigen   DocumentoFiscal?  @relation("Reverso", fields: [documentoOrigenId], references: [id])
  reversos          DocumentoFiscal[] @relation("Reverso")
  reasonTo          String?           @map("reason_to")
  fecha             DateTime          @db.Date
  hora              String // HH:MM:SS
  paymentMethod     String            @map("payment_method")
  currency          String            @default("VES")
  subtotal          Decimal           @db.Decimal(18, 2)
  totalTax          Decimal           @map("total_tax") @db.Decimal(18, 2)
  totalWTaxes       Decimal           @map("total_w_taxes") @db.Decimal(18, 2)
  igtf              Decimal           @default(0) @db.Decimal(18, 2)
  tasaBcv           Decimal           @map("tasa_bcv") @db.Decimal(18, 6) // tasa usada (RN-118)
  tasaMoneda        String            @default("USD") @map("tasa_moneda")
  desgloseIva       Json              @map("desglose_iva")
  thirdParty        Json?             @map("third_party")
  datosEnvio        Json?             @map("datos_envio") // guía de despacho: conductor, vehículo, direcciones
  items             DocumentoItem[]
  pagos             PagoDocumento[]
  createdAt         DateTime          @default(now()) @map("created_at")

  @@unique([contribuyenteId, tipo, puntoEmisionId, docNum]) // RN-128
  @@index([contribuyenteId])
  @@index([clienteTerceroId])
  @@map("documentos_fiscales")
}

model DocumentoItem {
  id            String          @id @default(uuid())
  documentoId   String          @map("documento_id")
  documento     DocumentoFiscal @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  productoId    String?         @map("producto_id")
  producto      Producto?       @relation(fields: [productoId], references: [id])
  tipoLinea     String          @default("item") @map("tipo_linea")
  descripcion   String
  codigo        String
  cantidad      Decimal         @db.Decimal(18, 3)
  costoUnit     Decimal         @map("costo_unit") @db.Decimal(18, 2)
  costoTotal    Decimal         @map("costo_total") @db.Decimal(18, 2)
  taxElm        String          @map("tax_elm") // G / E
  taxPercentage String          @map("tax_percentage") // "16%"
  pesoKg        Decimal?        @map("peso_kg") @db.Decimal(18, 3) // guía de despacho

  @@index([documentoId])
  @@map("documento_items")
}

model PagoDocumento {
  id          String          @id @default(uuid())
  documentoId String          @map("documento_id")
  documento   DocumentoFiscal @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  metodo      MetodoPago
  monto       Decimal         @db.Decimal(18, 2)
  esDivisa    Boolean         @default(false) @map("es_divisa") // activa IGTF (RN-010)
  referencia  String?
  banco       String?
  lotePos     String?         @map("lote_pos")

  @@index([documentoId])
  @@map("pagos_documento")
}

// ──────────────────────────────────────────────────────────────
// Compras y Retenciones — Módulo 04 — RN-011/104/127/129/132
// ──────────────────────────────────────────────────────────────

enum EstatusCompra {
  REGISTRADA
  PAGADA_PARCIAL
  PAGADA_TOTAL
}

enum TipoRetencion {
  IVA
  ISLR
}

/// Condición fiscal del sujeto retenido (ISLR): define tarifa y sustraendo (decreto 1.808).
enum CondicionFiscal {
  PNR // Persona Natural Residente
  PNNR // Persona Natural No Residente
  PJD // Persona Jurídica Domiciliada
  PJND // Persona Jurídica No Domiciliada
}

/// Factura de compra registrada a un proveedor (genera IVA crédito, RN-011).
model Compra {
  id                 String                 @id @default(uuid())
  contribuyenteId    String                 @map("contribuyente_id")
  contribuyente      Contribuyente          @relation(fields: [contribuyenteId], references: [id])
  proveedorTerceroId String                 @map("proveedor_tercero_id")
  proveedor          Tercero                @relation("ProveedorCompras", fields: [proveedorTerceroId], references: [id])
  numeroFactura      String                 @map("numero_factura") // doc del proveedor
  numeroControl      String?                @map("numero_control") // control fiscal del proveedor (para retención, RN-127)
  fecha              DateTime               @db.Date
  base               Decimal                @db.Decimal(18, 2) // base imponible
  ivaCredito         Decimal                @map("iva_credito") @db.Decimal(18, 2)
  total              Decimal                @db.Decimal(18, 2)
  estado             EstatusCompra          @default(REGISTRADA)
  pagos              PagoProveedor[]
  retenciones        ComprobanteRetencion[]
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  @@index([contribuyenteId])
  @@map("compras")
}

model PagoProveedor {
  id         String   @id @default(uuid())
  compraId   String   @map("compra_id")
  compra     Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  monto      Decimal  @db.Decimal(18, 2)
  referencia String?
  fecha      DateTime @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([compraId])
  @@map("pagos_proveedor")
}

/// Comprobante de Retención (IVA/ISLR) emitido por la imprenta. Inmutable (RN-132).
model ComprobanteRetencion {
  id                    String           @id @default(uuid())
  contribuyenteId       String           @map("contribuyente_id")
  contribuyente         Contribuyente    @relation(fields: [contribuyenteId], references: [id])
  compraId              String?          @map("compra_id")
  compra                Compra?          @relation(fields: [compraId], references: [id])
  tipo                  TipoRetencion
  docNum                String           @map("doc_num")
  numeroControl         String?          @map("numero_control") // lo asigna la imprenta
  estatus               EstatusDocumento @default(NO_ENVIADO)
  periodoYear           String           @map("periodo_year")
  periodoMonth          String           @map("periodo_month")
  beneficiarioTerceroId String           @map("beneficiario_tercero_id")
  beneficiario          Tercero          @relation("BeneficiarioRetenciones", fields: [beneficiarioTerceroId], references: [id])
  facDocumentNum        String           @map("fac_document_num") // factura referenciada (RN-127)
  facControlNum         String           @map("fac_control_num")
  base                  Decimal          @db.Decimal(18, 2)
  porcentaje            Decimal          @db.Decimal(5, 2)
  montoRetenido         Decimal          @map("monto_retenido") @db.Decimal(18, 2)
  conceptoIslr          String?          @map("concepto_islr") // solo ISLR
  sustraendo            Decimal          @default(0) @db.Decimal(18, 2) // solo ISLR a personas naturales
  condicionFiscal       CondicionFiscal? @map("condicion_fiscal") // solo ISLR (PNR/PNNR/PJD/PJND)
  fecha                 DateTime         @db.Date
  hora                  String
  createdAt             DateTime         @default(now()) @map("created_at")

  @@unique([contribuyenteId, tipo, docNum])
  @@index([contribuyenteId])
  @@map("comprobantes_retencion")
}

/// Retenciones que nos PRACTICAN los clientes (no las emitimos) — RN-133. Solo registro.
model RetencionRecibida {
  id              String        @id @default(uuid())
  contribuyenteId String        @map("contribuyente_id")
  contribuyente   Contribuyente @relation(fields: [contribuyenteId], references: [id])
  tipo            TipoRetencion // IVA / ISLR
  numero          String // nº del comprobante que emitió el agente (cliente)
  fecha           DateTime      @db.Date
  agenteRif       String        @map("agente_rif") // quién nos retuvo
  agenteNombre    String?       @map("agente_nombre")
  facturaRef      String?       @map("factura_ref") // nuestra factura sobre la que retuvieron
  base            Decimal       @db.Decimal(18, 2)
  monto           Decimal       @db.Decimal(18, 2)
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([contribuyenteId])
  @@map("retenciones_recibidas")
}

// ──────────────────────────────────────────────────────────────
// Contabilidad — Módulo 07 — RN-105/107/135
// ──────────────────────────────────────────────────────────────

enum TipoCuenta {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  GASTO
}

enum OrigenAsiento {
  AUTOMATICO
  MANUAL
}

/// Plan de cuentas por comercio. Sin precarga: cada uno lo crea desde cero (RN-135).
model PlanCuenta {
  id              String                 @id @default(uuid())
  contribuyenteId String                 @map("contribuyente_id")
  contribuyente   Contribuyente          @relation(fields: [contribuyenteId], references: [id])
  codigo          String
  nombre          String
  tipo            TipoCuenta
  activa          Boolean                @default(true)
  lineas          AsientoLinea[]
  configs         ConfigCuentaContable[]
  createdAt       DateTime               @default(now()) @map("created_at")

  @@unique([contribuyenteId, codigo])
  @@index([contribuyenteId])
  @@map("plan_cuentas")
}

/// Mapeo "evento contable → cuenta" para los asientos automáticos (RN-135/107).
model ConfigCuentaContable {
  id              String        @id @default(uuid())
  contribuyenteId String        @map("contribuyente_id")
  contribuyente   Contribuyente @relation(fields: [contribuyenteId], references: [id])
  evento          String // ej. venta_ingreso, iva_debito, igtf, retencion_iva...
  cuentaId        String        @map("cuenta_id")
  cuenta          PlanCuenta    @relation(fields: [cuentaId], references: [id])

  @@unique([contribuyenteId, evento])
  @@map("config_cuentas_contables")
}

/// Asiento contable (automático o manual). Σ debe = Σ haber (partida doble).
model Asiento {
  id              String         @id @default(uuid())
  contribuyenteId String         @map("contribuyente_id")
  contribuyente   Contribuyente  @relation(fields: [contribuyenteId], references: [id])
  fecha           DateTime       @db.Date
  glosa           String
  origen          OrigenAsiento  @default(MANUAL)
  documentoRef    String?        @map("documento_ref")
  lineas          AsientoLinea[]
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([contribuyenteId])
  @@map("asientos")
}

model AsientoLinea {
  id        String     @id @default(uuid())
  asientoId String     @map("asiento_id")
  asiento   Asiento    @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  cuentaId  String     @map("cuenta_id")
  cuenta    PlanCuenta @relation(fields: [cuentaId], references: [id])
  debe      Decimal    @default(0) @db.Decimal(18, 2)
  haber     Decimal    @default(0) @db.Decimal(18, 2)

  @@index([asientoId])
  @@map("asiento_lineas")
}

enum EstadoDeclaracion {
  PENDIENTE
  DECLARADA
  VERIFICADA
}

/// Declaración de un período (CT5/RN-108): prepara el paquete y lo marca como declarado.
/// NO declara ante el SENIAT (eso es manual en el portal); guarda el snapshot inmutable.
model Declaracion {
  id               String            @id @default(uuid())
  contribuyenteId  String            @map("contribuyente_id")
  contribuyente    Contribuyente     @relation(fields: [contribuyenteId], references: [id])
  tipo             TipoRetencion // IVA (ISLR a futuro)
  periodo          String // "2026-06"
  debitoFiscal     Decimal           @map("debito_fiscal") @db.Decimal(18, 2)
  creditoFiscal    Decimal           @map("credito_fiscal") @db.Decimal(18, 2)
  retenciones      Decimal           @db.Decimal(18, 2)
  montoADeclarar   Decimal           @map("monto_a_declarar") @db.Decimal(18, 2)
  estado           EstadoDeclaracion @default(DECLARADA)
  paquete          Json // snapshot de los libros/resumen al momento de declarar
  referencia       String? // nro de comprobante/planilla del portal (si lo cargan)
  fechaDeclaracion DateTime          @default(now()) @map("fecha_declaracion")

  @@unique([contribuyenteId, tipo, periodo])
  @@index([contribuyenteId])
  @@map("declaraciones")
}

// ──────────────────────────────────────────────────────────────
// Ventas — Módulo 03 (ciclo comercial previo a la factura) — RN-103
// ──────────────────────────────────────────────────────────────

enum EstadoVenta {
  COTIZACION
  CONFIRMADA
  FACTURADA
  ANULADA
}

/// Venta/cotización: NO es documento fiscal (RN-103). Puede derivar en factura.
model Venta {
  id                String        @id @default(uuid())
  contribuyenteId   String        @map("contribuyente_id")
  contribuyente     Contribuyente @relation(fields: [contribuyenteId], references: [id])
  terceroId         String        @map("tercero_id")
  tercero           Tercero       @relation("VentasTercero", fields: [terceroId], references: [id])
  estado            EstadoVenta   @default(COTIZACION)
  totalEstimado     Decimal       @map("total_estimado") @db.Decimal(18, 2)
  documentoFiscalId String?       @map("documento_fiscal_id") // factura generada (si se facturó)
  items             VentaItem[]
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([contribuyenteId])
  @@map("ventas")
}

model VentaItem {
  id          String   @id @default(uuid())
  ventaId     String   @map("venta_id")
  venta       Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId  String   @map("producto_id")
  producto    Producto @relation(fields: [productoId], references: [id])
  descripcion String
  cantidad    Decimal  @db.Decimal(18, 3)
  precio      Decimal  @db.Decimal(18, 2) // precio al momento de la cotización

  @@index([ventaId])
  @@map("venta_items")
}

// ──────────────────────────────────────────────────────────────
// Impuestos Municipales — Módulo 09
// ──────────────────────────────────────────────────────────────

enum EstadoImpuesto {
  PENDIENTE
  PAGADO
}

/// Actividad económica municipal del contribuyente (cada una con su alícuota).
model ActividadEconomica {
  id              String              @id @default(uuid())
  contribuyenteId String              @map("contribuyente_id")
  contribuyente   Contribuyente       @relation(fields: [contribuyenteId], references: [id])
  codigo          String
  descripcion     String
  alicuota        Decimal             @db.Decimal(5, 2) // %
  activa          Boolean             @default(true)
  impuestos       ImpuestoMunicipal[]
  createdAt       DateTime            @default(now()) @map("created_at")

  @@unique([contribuyenteId, codigo])
  @@index([contribuyenteId])
  @@map("actividades_economicas")
}

/// Impuesto municipal calculado por período sobre una actividad. Pago presencial/online se registra.
model ImpuestoMunicipal {
  id              String             @id @default(uuid())
  contribuyenteId String             @map("contribuyente_id")
  contribuyente   Contribuyente      @relation(fields: [contribuyenteId], references: [id])
  actividadId     String             @map("actividad_id")
  actividad       ActividadEconomica @relation(fields: [actividadId], references: [id])
  periodo         String // "2026-06"
  base            Decimal            @db.Decimal(18, 2)
  monto           Decimal            @db.Decimal(18, 2)
  estado          EstadoImpuesto     @default(PENDIENTE)
  referenciaPago  String?            @map("referencia_pago")
  fechaPago       DateTime?          @map("fecha_pago") @db.Date
  createdAt       DateTime           @default(now()) @map("created_at")

  @@index([contribuyenteId])
  @@map("impuestos_municipales")
}

// ──────────────────────────────────────────────────────────────
// Autenticación y RBAC granular (Módulo 11 / ADR-0002)
// ──────────────────────────────────────────────────────────────

/// Usuario del sistema. Pertenece a un Contribuyente (NULL = admin Sirumatek).
model Usuario {
  id                   String               @id @default(uuid())
  contribuyenteId      String?              @map("contribuyente_id")
  contribuyente        Contribuyente?       @relation(fields: [contribuyenteId], references: [id])
  email                String               @unique
  emailAlternativo     String?              @map("email_alternativo") // recuperación (RN-014)
  passwordHash         String               @map("password_hash")
  passwordTemporal     Boolean              @default(false) @map("password_temporal") // fuerza cambio (RN-014)
  nombre               String
  activo               Boolean              @default(true)
  ultimoAcceso         DateTime?            @map("ultimo_acceso")
  roles                UsuarioRol[]
  refreshTokens        RefreshToken[]
  credencialesWebAuthn CredencialWebAuthn[]
  auditoria            RegistroAuditoria[]
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")

  @@index([contribuyenteId])
  @@map("usuarios")
}

/// Rol: agrupa permisos y se asigna a usuarios. Semilla: Administrador, Operador, Fiscal, Sirumatek.
model Rol {
  id          String       @id @default(uuid())
  nombre      String       @unique
  descripcion String?
  usuarios    UsuarioRol[]
  permisos    RolPermiso[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

/// Permiso granular: una acción sobre un módulo (ej. facturas:anular).
model Permiso {
  id          String       @id @default(uuid())
  modulo      String
  accion      String
  descripcion String?
  roles       RolPermiso[]

  @@unique([modulo, accion])
  @@map("permisos")
}

/// Relación N:M usuario ↔ rol.
model UsuarioRol {
  usuarioId String  @map("usuario_id")
  rolId     String  @map("rol_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
  @@map("usuarios_roles")
}

/// Relación N:M rol ↔ permiso.
model RolPermiso {
  rolId     String  @map("rol_id")
  permisoId String  @map("permiso_id")
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("roles_permisos")
}

/// Refresh tokens (hash) para rotación y revocación de sesión.
model RefreshToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  usuarioId String   @map("usuario_id")
  tokenHash String   @map("token_hash")
  expiraEn  DateTime @map("expira_en")
  revocado  Boolean  @default(false)
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([usuarioId])
  @@map("refresh_tokens")
}

/// Credencial WebAuthn (passkey) enrolada por el usuario: huella/Face ID/Windows Hello.
/// counter detecta clonación de authenticator (debe crecer estrictamente en cada uso).
model CredencialWebAuthn {
  id           String    @id @default(uuid())
  usuarioId    String    @map("usuario_id")
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  credentialId String    @unique @map("credential_id")
  publicKey    Bytes     @map("public_key")
  counter      BigInt    @default(0)
  deviceLabel  String?   @map("device_label")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")

  @@index([usuarioId])
  @@map("credenciales_webauthn")
}

/// Challenge efímero de una ceremonia WebAuthn (registro o login) mientras el
/// navegador consulta al authenticator. usuarioId es null en login sin
/// username (discoverable credential): el challenge no está atado a nadie
/// hasta que la respuesta llega y se resuelve por credentialId.
model WebAuthnChallenge {
  id        String   @id @default(uuid())
  usuarioId String?  @map("usuario_id")
  challenge String
  expiraEn  DateTime @map("expira_en")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("webauthn_challenges")
}

// ──────────────────────────────────────────────────────────────
// Auditoría (append-only) — RN-004, U-L1
// ──────────────────────────────────────────────────────────────

/// Registro inmutable de operaciones sensibles. Solo se inserta; nunca se edita/borra.
model RegistroAuditoria {
  id              String         @id @default(uuid())
  usuarioId       String?        @map("usuario_id")
  usuario         Usuario?       @relation(fields: [usuarioId], references: [id])
  contribuyenteId String?        @map("contribuyente_id")
  contribuyente   Contribuyente? @relation(fields: [contribuyenteId], references: [id])
  ip              String?
  fechaHora       DateTime       @default(now()) @map("fecha_hora")
  accion          String // login, emitir, anular, asiento...
  entidad         String? // tabla/recurso afectado
  entidadId       String?        @map("entidad_id")
  detalle         Json?

  @@index([usuarioId])
  @@index([contribuyenteId])
  @@index([fechaHora])
  @@map("registro_auditoria")
}

// ──────────────────────────────────────────────────────────────
// Tasas (caché de fallback) — RN-117
// La tasa la provee el microservicio externo tasas-bcv; aquí solo se
// persiste la última conocida para usar si el micro no responde.
// ──────────────────────────────────────────────────────────────

model TasaCache {
  curCod    String   @map("cur_cod") // USD / EUR
  validFrom DateTime @map("valid_from") @db.Date
  ratExc    Decimal  @map("rat_exc") @db.Decimal(18, 6)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([curCod, validFrom])
  @@map("tasa_cache")
}
